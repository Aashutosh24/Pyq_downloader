{
  "manifest_version": 3,
  "name": "Smart PYQ Finder",
  "version": "1.0",
  "description": "Find and organize Previous Year Question Papers using course code and exam type",

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "PYQ Finder"
  },

  "background": {
    "service_worker": "background.js"
  },

  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],

  "host_permissions": [
    "*://*/*"
  ]
}
